#!/bin/bash
# Initialize Fabric blockchain (via microfab) using blockchain and deploy the chaincode (via deploy_chaincode.py). Use the configuration in the config directory and the chaincode inside the chaincode directory
set -e
MICROFAB_CFG_PATH=config/config.json
DEPLOY_CC_SCRIPT=scripts/deploy_chaincode.py
export FABRIC_CFG_PATH=$(pwd)/config

echo "IMPORTANT: Before running this script, configure $MICROFAB_CFG_PATH and put your chaincode inside the chaincode directory."


# Since the init script resets the blockchain, you need to "reset" the IPFS logs as well (i.e., point to nothing)
echo "Regenerating the IPNS key. IMPORTANT: Remove in production"
docker compose down -v
rm -f api/keys/ipns-key.key 

echo "Starting Kubo (IPFS) via docker compose (persistent volume)..."
docker compose up -d ipfs
sleep 5

# Ensure IPNS key exists in api/keys/ipns-key.key (libp2p Ed25519 format, NOT PEM).
# The FILE is the source of truth. Flow: FILE -> KUBO (never Kubo -> file)
# 1. If file doesn't exist: generate new key, save to file, import to Kubo
# 2. If file exists: remove key from Kubo (if exists) and import from file
IPNS_KEY_FILE=api/keys/ipns-key.key
IPNS_KEY_NAME=transparency


if [ ! -s "$IPNS_KEY_FILE" ]; then
  # File doesn't exist or is empty -> generate new key
  echo "Generating new IPNS key (Ed25519) and saving to $IPNS_KEY_FILE..."
  mkdir -p api/keys
  # Generate in Kubo temporarily to get the key file
  docker exec fabric-transparency-ipfs ipfs key gen temp-ipns-gen --type=ed25519 >/dev/null
  docker exec fabric-transparency-ipfs ipfs key export temp-ipns-gen -o /tmp/ipns-new.key
  docker cp fabric-transparency-ipfs:/tmp/ipns-new.key "$IPNS_KEY_FILE"
  docker exec fabric-transparency-ipfs ipfs key rm temp-ipns-gen >/dev/null 2>&1 || true
  docker exec fabric-transparency-ipfs rm -f /tmp/ipns-new.key
  echo "IPNS key file created: $IPNS_KEY_FILE"
fi

# Now import the file to Kubo (always, to ensure Kubo matches the file)
echo "Importing IPNS key from $IPNS_KEY_FILE to Kubo as '${IPNS_KEY_NAME}'..."
# Remove existing key in Kubo if present
docker exec fabric-transparency-ipfs ipfs key rm "${IPNS_KEY_NAME}" >/dev/null 2>&1 || true
# Import from file
docker cp "$IPNS_KEY_FILE" fabric-transparency-ipfs:/tmp/ipns-key.key
docker exec fabric-transparency-ipfs ipfs key import "${IPNS_KEY_NAME}" /tmp/ipns-key.key
docker exec fabric-transparency-ipfs rm -f /tmp/ipns-key.key
echo "IPNS key '${IPNS_KEY_NAME}' synced from file to Kubo."

echo "Stopping previous microfab container (if any)..."
docker rm -f microfab >/dev/null 2>&1 || true

docker network prune -f
sleep 2

echo "Starting blockchain using $MICROFAB_CFG_PATH configuration..."
export MICROFAB_CONFIG=$(cat $MICROFAB_CFG_PATH)
docker run -d --name microfab --rm -p 8080:8080 -e MICROFAB_CONFIG ibmcom/ibp-microfab
sleep 4

echo "Creating wallet, gateways and msp directories..."
# curl -s http://console.127-0-0-1.nip.io:8080/ak/api/v1/components | weft microfab -w ./wallets -p ./gateways -m ./msp -f
# IMPORTANT: uncomment if you haven't installed weftility globally
npm install @hyperledgendary/weftility
curl -s http://console.127-0-0-1.nip.io:8080/ak/api/v1/components | npx weft microfab -w ./wallets -p ./gateways -m ./msp -f

#Deploy chaincode
python3 $DEPLOY_CC_SCRIPT || exit 1

echo -e
echo -e "\033[0;32mBlockchain up and running!\033[0m"
echo -e


### API ####
cd api

echo "Installing dependencies..."
npm install

# IPNS is NOT reset on init - previously published IPFS content remains visible.
# To reset IPNS to empty (e.g. for a fresh demo), run: INIT_RESET_IPNS=1 ./init

if [ "${INIT_RESET_IPNS}" = "1" ]; then
  echo "Resetting IPNS to empty placeholder (INIT_RESET_IPNS=1)..."
  node scripts/publish-empty-ipns.js
fi

echo -e "Initializing API..."
node app

